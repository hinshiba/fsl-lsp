/*
 *  BitN.fsl
 *
 *  Bit(n) 型に対する定数生成関数を提供する組込みプレリュード．
 *  LSP に内蔵され，全ソースへ暗黙的にインクルードされる．
 *  これにより `Bit(n).zero` 等の参照が未宣言シンボル扱いされない．
 */

module Bit {
  /* 全ビットが 0 の Bit(n) 定数 */
  def zero(n): Bit(n) = 0b0

  /* 最下位ビットのみ 1 の Bit(n) 定数 */
  def one(n): Bit(n) = 0b1

  /* 全ビットが 1 の Bit(n) 定数 */
  def allOne(n): Bit(n) = ~0b0
}
