{
  "name": "fsl-lsp-code",
  "displayName": "fsl-lsp-code",
  "description": "fsl言語サービスを提供",
  "version": "0.2.0",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "github.com:hinshiba/fsl-lsp.git"
  },
  "engines": {
    "vscode": "^1.116.0"
  },
  "type": "module",
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "fsl",
        "aliases": [
          "FSL",
          "fsl"
        ],
        "extensions": [
          ".fsl"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "fsl",
        "scopeName": "source.fsl",
        "path": "./syntaxes/fsl.tmLanguage.json"
      }
    ]
  },
  "scripts": {
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node scripts/esbuild.ts --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "copy-bin": "node scripts/copy-bin.ts",
    "pack": "vsce package --no-dependencies",
    "esbuild": "node scripts/esbuild.ts",
    "check-types": "tsc --noEmit",
    "lint": "eslint src"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "~22.19.17",
    "@types/vscode": "^1.116.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.9.1",
    "esbuild": "^0.27.3",
    "eslint": "^9.39.3",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  }
}